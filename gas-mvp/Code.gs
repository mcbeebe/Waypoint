  e.push(['xref-all','cross-reference','eligibility','Diagnosis Service Eligibility Matrix','SERVICE ELIGIBILITY MATRIX BY DIAGNOSIS\n\nAutism: RC=YES, IEP=YES, 504Plan=CONDITIONAL, SSI=YES, IHSS=YES, MediCal=YES, CCS=CONDITIONAL, \nIntellectual Disability: RC=YES, IEP=YES, 504Plan=CONDITIONAL, SSI=YES, IHSS=YES, MediCal=YES, CCS=CONDITIONAL, \nCerebral Palsy: RC=YES, IEP=YES, 504Plan=CONDITIONAL, SSI=YES, IHSS=YES, MediCal=YES, CCS=YES, \nEpilepsy: RC=YES, IEP=YES, 504Plan=YES, SSI=YES, IHSS=CONDITIONAL, MediCal=YES, CCS=YES, \nDown Syndrome: RC=YES, IEP=YES, 504Plan=CONDITIONAL, SSI=YES, IHSS=YES, MediCal=YES, CCS=CONDITIONAL, \nSpeech/Language Only: RC=CONDITIONAL, IEP=YES, 504Plan=YES, SSI=CONDITIONAL, IHSS=NO, MediCal=YES, CCS=NO, \nADHD Only: RC=NO, IEP=CONDITIONAL, 504Plan=YES, SSI=CONDITIONAL, IHSS=NO, MediCal=YES, CCS=NO, \nSpecific Learning Disability: RC=NO, IEP=YES, 504Plan=YES, SSI=CONDITIONAL, IHSS=NO, MediCal=YES, CCS=NO, \nMuscular Dystrophy: RC=YES, IEP=YES, 504Plan=CONDITIONAL, SSI=YES, IHSS=YES, MediCal=YES, CCS=YES, \nTraumatic Brain Injury: RC=YES, IEP=YES, 504Plan=YES, SSI=YES, IHSS=YES, MediCal=YES, CCS=CONDITIONAL, \nDeaf / Hard of Hearing: RC=CONDITIONAL, IEP=YES, 504Plan=YES, SSI=YES, IHSS=CONDITIONAL, MediCal=YES, CCS=CONDITIONAL, \nBlind / Visually Impaired: RC=CONDITIONAL, IEP=YES, 504Plan=YES, SSI=YES, IHSS=CONDITIONAL, MediCal=YES, CCS=CONDITIONAL, \nMultiple Disabilities: RC=YES, IEP=YES, 504Plan=CONDITIONAL, SSI=YES, IHSS=YES, MediCal=YES, CCS=YES, \nEmotional Disturbance: RC=CONDITIONAL, IEP=YES, 504Plan=YES, SSI=CONDITIONAL, IHSS=CONDITIONAL, MediCal=YES, CCS=NO, \nOther Health Impairment: RC=CONDITIONAL, IEP=YES, 504Plan=YES, SSI=CONDITIONAL, IHSS=CONDITIONAL, MediCal=YES, CCS=CONDITIONAL, \nDyslexia / Dyscalculia: RC=NO, IEP=YES, 504Plan=YES, SSI=NO, IHSS=NO, MediCal=YES, CCS=NO, \n','Entity Matrix v9.4','TRUE',now]);
