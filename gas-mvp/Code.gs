  e.push(['age-birth-3','age-timeline','birth-3','Age Birth–3: Early Intervention','AGE: Birth–3 — Early Intervention\n\nENTITIES: Regional Center (Early Start), Medi-Cal, CCS, Private Insurance, Early Intervention therapists, CalABLE\n\nACTIONS: • Refer to RC immediately if developmental concerns\n• 45-day assessment timeline\n• IFSP within 45 days of referral\n• IFSP review every 6 months\n• Begin transition planning at 2.5 years\n• Refer to school district for Part B evaluation\n• Open CalABLE account (no minimum age — $19K/year tax-advantaged savings for disability expenses without affecting SSI/Medi-Cal)\n\nTRANSITIONS: • Hospital → Home (NICU follow-up)\n• Diagnosis → RC intake\n• Age 2.5: Part C → Part B transition planning begins\n• Age 3: IFSP → IEP transition\n\nDOCUMENTS: IFSP, medical records, Early Start evaluations, transition plan, school district referral, CalABLE enrollment\n\n','Entity Matrix v9.4','TRUE',now]);
  e.push(['age-3-5','age-timeline','3-5','Age 3–5: Preschool / Early Childhood','AGE: 3–5 — Preschool / Early Childhood\n\nENTITIES: School District (IEP), Regional Center, Medi-Cal, CCS, Private Insurance, SELPA, CalABLE\n\nACTIONS: • IEP must be in place by 3rd birthday\n• Inclusive preschool placement discussion (LRE)\n• Triennial re-evaluation\n• Choose preschool (Undivided: school tour checklist)\n• Apply for SSI if eligible\n• Apply for IHSS if eligible\n• Open CalABLE account (no minimum age — $19K/year tax-advantaged savings for disability expenses without affecting SSI/Medi-Cal)\n\nTRANSITIONS: • RC → School District (IFSP → IEP)\n• Home → Preschool\n• Preschool → Kindergarten (transition IEP)\n\nDOCUMENTS: IEP, assessment reports, preschool tour checklist, SSI application, IHSS application, CalABLE enrollment\n\n','Entity Matrix v9.4','TRUE',now]);
  e.push(['age-5-11','age-timeline','5-11','Age 5–11: Elementary School','AGE: 5–11 — Elementary School\n\nENTITIES: School District (IEP/504), RC, IHSS, SSI, Medi-Cal, CCS, Private Insurance, ERMHS, CalABLE\n\nACTIONS: • Annual IEP review\n• Triennial re-evaluation\n• Track IEP service delivery (use DRC tracking log)\n• Request additional assessments if new concerns\n• Monitor progress reports\n• Address behavioral needs (BIP, ERMHS)\n• Request IEE if disagree with assessments\n• Open CalABLE account (no minimum age — $19K/year tax-advantaged savings for disability expenses without affecting SSI/Medi-Cal)\n\nTRANSITIONS: • Kindergarten entry\n• Grade-level transitions\n• Elementary → Middle School (transition IEP)\n\nDOCUMENTS: IEP, progress reports, assessment reports, BIP, service tracking log, IEE reports, CalABLE enrollment\n\n','Entity Matrix v9.4','TRUE',now]);
