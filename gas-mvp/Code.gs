function saveUser(userData) {
  try {
    var sheet = getOrCreateSheet_('Users', [
      'id', 'email', 'parentName', 'childName', 'diagnosis', 'age', 'birthday',
      'diagnosedBy', 'rcStatus', 'iepStatus', 'insurance', 'zipCode',
      'regionalCenter', 'createdAt', 'lastActive'
    ]);
    var id = Utilities.getUuid();
    var now = new Date().toISOString();
    sheet.appendRow([
      id,
      userData.email || '',
      userData.parentName || '',
      userData.childName || '',
      userData.diagnosis || '',
      userData.age || '',
      userData.birthday || '',
      userData.diagnosedBy || '',
      userData.rcStatus || '',
      userData.iepStatus || '',
      userData.insurance || '',
      userData.zipCode || '',
      userData.regionalCenter || '',
      userData.familyStructure || '',   // WP-013
      userData.militaryStatus || '',    // WP-013
      userData.ruralStatus || '',       // WP-013
      userData.immigrationConcerns || '', // WP-013
      now,
      now
    ]);
    return { success: true, userId: id };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function logAction(userId, actionId, title, status, followUpAnswer, notes) {
  try {
    var sheet = getOrCreateSheet_('ActionLog', [
      'userId', 'actionId', 'title', 'status', 'completedAt', 'followUpAnswer', 'notes'
    ]);
    sheet.appendRow([
      userId, actionId, title, status,
      status === 'completed' ? new Date().toISOString() : '',
      followUpAnswer || '',
      notes || ''
    ]);
    return { success: true };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

// WP-019: Retrieve action history timeline
function getActionHistory(userId) {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('ActionLog');
    if (!sheet || sheet.getLastRow() < 2) return {success:true, history:[]};
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    var history = [];
    for (var i = 1; i < data.length; i++) {
      var row = {};
      for (var j = 0; j < headers.length; j++) row[headers[j]] = data[i][j];
      if (row.userId === userId) {
        history.push({
          actionId: row.actionId || '',
          title: row.title || '',
          status: row.status || '',
          date: row.completedAt || '',
          followUp: row.followUpAnswer || '',
          notes: row.notes || ''
        });
      }
    }
    history.sort(function(a,b){ return (b.date||'').localeCompare(a.date||''); });
    return {success:true, history:history};
  } catch(e) { return {success:false, error:e.toString(), history:[]}; }
}

// ─── WP-001: Server-side action state persistence ───
function saveActionState(userId, completedActions, dismissedActions, startedActions) {
  try {
    if (!userId) return { success: false, error: 'No userId' };
    var sheet = getOrCreateSheet_('ActionLog', [
      'userId', 'actionId', 'title', 'status', 'completedAt', 'followUpAnswer', 'notes'
    ]);
    var data = sheet.getLastRow() > 1
      ? sheet.getRange(2, 1, sheet.getLastRow() - 1, 7).getValues()
      : [];

    // Build lookup of existing rows by actionId for this user
    var existingRows = {};
    for (var i = 0; i < data.length; i++) {
      if (data[i][0] === userId) {
        existingRows[data[i][1]] = i + 2; // sheet row (1-indexed + header)
      }
    }

    var now = new Date().toISOString();
    var completed = completedActions || {};
    var dismissed = dismissedActions || {};
    var started = startedActions || {};

    // Merge all action IDs
    var allIds = {};
    var k;
    for (k in completed) allIds[k] = true;
    for (k in dismissed) allIds[k] = true;
    for (k in started) allIds[k] = true;

    for (var id in allIds) {
      var status = completed[id] ? 'completed' : dismissed[id] ? 'dismissed' : 'started';
      if (existingRows[id]) {
        // Update existing row's status
        var row = existingRows[id];
        sheet.getRange(row, 4).setValue(status);
        if (status === 'completed') sheet.getRange(row, 5).setValue(now);
      } else {
        // Append new row
        sheet.appendRow([userId, id, '', status, status === 'completed' ? now : '', '', '']);
      }
    }
    return { success: true };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function getActionState(userId) {
  try {
    if (!userId) return { success: false, error: 'No userId' };
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('ActionLog');
    if (!sheet || sheet.getLastRow() <= 1) {
      return { success: true, completed: {}, dismissed: {}, started: {} };
    }
    var data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 7).getValues();
    var completed = {}, dismissed = {}, started = {};
    for (var i = 0; i < data.length; i++) {
      if (data[i][0] !== userId) continue;
      var actionId = data[i][1];
      var status = data[i][3];
      if (status === 'completed') completed[actionId] = true;
      else if (status === 'dismissed') dismissed[actionId] = true;
      else if (status === 'started') started[actionId] = { startedAt: data[i][4] || '' };
    }
    return { success: true, completed: completed, dismissed: dismissed, started: started };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

// ─── WP-031: Action Editing — Update action fields ───
function updateAction(userId, actionId, edits) {
  try {
    if (!userId || !actionId) return { success: false, error: 'Missing userId or actionId' };
    var sheet = getOrCreateSheet_('ActionEdits', [
      'userId', 'actionId', 'editedTitle', 'deadline', 'priority', 'userNotes', 'editedAt'
    ]);

    // Check for existing edit row
    var data = sheet.getLastRow() > 1
      ? sheet.getRange(2, 1, sheet.getLastRow() - 1, 7).getValues()
      : [];
    var existingRow = -1;
    for (var i = 0; i < data.length; i++) {
      if (data[i][0] === userId && data[i][1] === actionId) {
        existingRow = i + 2; // 1-indexed + header
        break;
      }
    }

    var now = new Date().toISOString();
    var rowData = [
      userId, actionId,
      edits.title || '',
      edits.deadline || '',
      edits.priority || '',
      edits.notes || '',
      now
    ];

    if (existingRow > 0) {
      sheet.getRange(existingRow, 1, 1, 7).setValues([rowData]);
    } else {
      sheet.appendRow(rowData);
    }
    return { success: true };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

// WP-031: Retrieve all action edits for a user
function getActionEdits(userId) {
  try {
    if (!userId) return { success: true, edits: {} };
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('ActionEdits');
    if (!sheet || sheet.getLastRow() <= 1) return { success: true, edits: {} };

    var data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 7).getValues();
    var edits = {};
    for (var i = 0; i < data.length; i++) {
      if (data[i][0] === userId) {
        edits[data[i][1]] = {
          title: data[i][2] || '',
          deadline: data[i][3] || '',
          priority: data[i][4] || '',
          notes: data[i][5] || '',
          editedAt: data[i][6] || ''
        };
      }
    }
    return { success: true, edits: edits };
  } catch (e) {
    return { success: false, error: e.toString(), edits: {} };
  }
}

// WP-001: Heartbeat ping for session timeout detection
function heartbeat(userId) {
  try {
    if (userId) {
      var sheet = getOrCreateSheet_('Sessions', ['userId', 'sessionStart', 'lastScreen', 'checkInData']);
      // Just touch the session to keep it alive — lightweight
    }
    return { success: true, ts: new Date().toISOString() };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function logSession(userId, screen, checkInData) {
