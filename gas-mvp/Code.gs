// ═══════════════════════════════════════════════════════
// WP-024: Universal Calendar Export (.ics)
// ═══════════════════════════════════════════════════════

function generateICS(eventData) {
  try {
    var title = eventData.title || 'Waypoint Reminder';
    var description = (eventData.description || '').replace(/\n/g, '\\n');
    var location = eventData.location || '';
    var dtStart = eventData.dateStr || '';
    var uid = Utilities.getUuid() + '@waypoint';
    var now = Utilities.formatDate(new Date(), 'UTC', "yyyyMMdd'T'HHmmss'Z'");

    // If dateStr is YYYY-MM-DD, make it an all-day event
    var isAllDay = /^\d{4}-\d{2}-\d{2}$/.test(dtStart);
    var dtStartFmt = isAllDay ? dtStart.replace(/-/g, '') : dtStart;
    var dtEndFmt = dtStartFmt;
    if (isAllDay) {
      // All-day events: DTEND is next day
      var d = new Date(dtStart + 'T00:00:00');
      d.setDate(d.getDate() + 1);
      dtEndFmt = Utilities.formatDate(d, 'UTC', 'yyyyMMdd');
    }

    var lines = [
      'BEGIN:VCALENDAR',
      'VERSION:2.0',
      'PRODID:-//Waypoint//Action Plan//EN',
      'CALSCALE:GREGORIAN',
      'METHOD:PUBLISH',
      'BEGIN:VEVENT',
      'UID:' + uid,
      'DTSTAMP:' + now,
    ];
    if (isAllDay) {
      lines.push('DTSTART;VALUE=DATE:' + dtStartFmt);
      lines.push('DTEND;VALUE=DATE:' + dtEndFmt);
    } else {
      lines.push('DTSTART:' + dtStartFmt);
      lines.push('DTEND:' + dtStartFmt);
    }
    lines.push('SUMMARY:' + title);
    if (description) lines.push('DESCRIPTION:' + description);
    if (location) lines.push('LOCATION:' + location);
    lines.push('BEGIN:VALARM');
    lines.push('TRIGGER:-P1D');
    lines.push('ACTION:DISPLAY');
    lines.push('DESCRIPTION:Reminder: ' + title);
    lines.push('END:VALARM');
    lines.push('END:VEVENT');
    lines.push('END:VCALENDAR');

    return { success: true, icsContent: lines.join('\r\n') };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

// ═══════════════════════════════════════════════════════
// WP-025: Email Reminders for Upcoming Deadlines
// ═══════════════════════════════════════════════════════

function sendDeadlineReminders() {
  try {
    var usersSheet = getOrCreateSheet_('Users', []);
    var actionSheet = getOrCreateSheet_('ActionLog', []);
    if (usersSheet.getLastRow() < 2) return { success: true, sent: 0 };

    var userData = usersSheet.getDataRange().getValues();
    var uHeaders = userData[0];
    var actionData = actionSheet.getLastRow() >= 2 ? actionSheet.getDataRange().getValues() : [actionSheet.getRange(1,1,1,actionSheet.getLastColumn()).getValues()[0]];
    var aHeaders = actionData[0];
    var sent = 0;

    for (var u = 1; u < userData.length; u++) {
      var user = {};
      for (var j = 0; j < uHeaders.length; j++) user[uHeaders[j]] = userData[u][j];
      if (!user.email) continue;

      var pref = user.reminderPref || 'weekly';
      if (pref === 'off') continue;

      // Gather completed actions for this user
      var completedIds = {};
      for (var a = 1; a < actionData.length; a++) {
        var aRow = {};
        for (var k = 0; k < aHeaders.length; k++) aRow[aHeaders[k]] = actionData[a][k];
        if (aRow.userId === user.id && aRow.status === 'completed') completedIds[aRow.actionId] = true;
      }

      // Build deadline items (simplified — based on known action patterns)
      var deadlines = [];
      var now = new Date();
      var weekFromNow = new Date(now.getTime() + 7 * 86400000);

      // Check common deadlines
      if (user.rcStatus === 'in_progress' && !completedIds['rc_call']) {
        deadlines.push({ title: 'Schedule RC Intake Call', urgency: 'this_week', note: 'Regional Center intake has a 120-day timeline' });
      }
      if (user.iepStatus === 'in_progress' && !completedIds['iep_request_eval']) {
        deadlines.push({ title: 'Follow Up on IEP Evaluation Request', urgency: 'this_week', note: 'School must respond within 15 days of request' });
      }

      if (deadlines.length === 0) continue;

      // Build HTML email
      var html = '<div style="font-family:Arial,sans-serif;max-width:600px;margin:0 auto">';
      html += '<div style="background:#1B2A4A;color:#fff;padding:20px;border-radius:12px 12px 0 0">';
      html += '<h2 style="margin:0">🧭 Waypoint — Deadline Reminder</h2>';
      html += '<p style="margin:4px 0 0;opacity:0.7">For ' + (user.childName || 'your child') + '\'s action plan</p></div>';
      html += '<div style="background:#fff;border:1px solid #E5E7EB;padding:20px;border-radius:0 0 12px 12px">';

      deadlines.forEach(function(d) {
        var color = d.urgency === 'overdue' ? '#DC2626' : d.urgency === 'this_week' ? '#D97706' : '#2563EB';
        html += '<div style="border-left:4px solid ' + color + ';padding:12px;margin-bottom:12px;background:#F9FAFB;border-radius:0 8px 8px 0">';
        html += '<strong>' + d.title + '</strong>';
        if (d.note) html += '<p style="margin:4px 0 0;font-size:13px;color:#6B7280">' + d.note + '</p>';
        html += '</div>';
      });

      html += '<p style="font-size:12px;color:#9CA3AF;margin-top:16px">Sent by Waypoint. Manage preferences in your profile.</p>';
      html += '</div></div>';

      MailApp.sendEmail({
        to: user.email,
        subject: '🧭 Waypoint: ' + deadlines.length + ' upcoming deadline' + (deadlines.length > 1 ? 's' : '') + ' for ' + (user.childName || 'your child'),
        htmlBody: html
      });
      sent++;
    }

    return { success: true, sent: sent };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function setupReminderTrigger() {
  // Remove existing triggers for this function
  var triggers = ScriptApp.getProjectTriggers();
  triggers.forEach(function(t) {
    if (t.getHandlerFunction() === 'sendDeadlineReminders') ScriptApp.deleteTrigger(t);
  });
  // Daily at 8 AM
  ScriptApp.newTrigger('sendDeadlineReminders')
    .timeBased()
    .everyDays(1)
    .atHour(8)
    .create();
  return { success: true, message: 'Daily reminder trigger created at 8 AM' };
}

function setReminderPreference(userId, pref) {
  try {
    var sheet = getOrCreateSheet_('Users', []);
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    var colIdx = headers.indexOf('reminderPref');
    if (colIdx === -1) {
      colIdx = headers.length;
      sheet.getRange(1, colIdx + 1).setValue('reminderPref');
    }
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] === userId) {
        sheet.getRange(i + 1, colIdx + 1).setValue(pref);
        return { success: true };
      }
    }
    return { success: false, error: 'User not found' };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

