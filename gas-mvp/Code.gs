// ─── Analytics helpers ───
function getUserCount() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Users');
    if (!sheet) return 0;
    return Math.max(0, sheet.getLastRow() - 1);
  } catch (e) {
    return 0;
  }
}

function getActionStats() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('ActionLog');
    if (!sheet || sheet.getLastRow() <= 1) return { total: 0, completed: 0 };
    var data = sheet.getRange(2, 1, sheet.getLastRow() - 1, 4).getValues();
    var total = data.length;
    var completed = data.filter(function(r) { return r[3] === 'completed'; }).length;
    return { total: total, completed: completed };
  } catch (e) {
    return { total: 0, completed: 0 };
  }
}

// ═══════════════════════════════════════════════════════
// AI ENGINE — Claude API Integration
// ═══════════════════════════════════════════════════════

function callClaude_(systemPrompt, userMessage, chatHistory, modelOverride) {
  var apiKey = getApiKey_();
  if (!apiKey) {
    throw new Error('ANTHROPIC_API_KEY not set. Go to Project Settings → Script Properties and add it.');
  }

  // WP-032: Build messages array with conversation history for continuity
  var messages = [];
  if (chatHistory && chatHistory.length > 0) {
    // Include last 6 messages max to stay within token budget
    var recentHistory = chatHistory.slice(-6);
    for (var i = 0; i < recentHistory.length; i++) {
      var msg = recentHistory[i];
      messages.push({
        role: msg.role === 'ai' ? 'assistant' : 'user',
        content: msg.content || ''
      });
    }
  }
  // Always append the current user message
  messages.push({ role: 'user', content: userMessage });

  var payload = {
    model: modelOverride || AI_CONFIG.MODEL,
    max_tokens: AI_CONFIG.MAX_TOKENS,
    system: [
      { type: 'text', text: systemPrompt, cache_control: { type: 'ephemeral' } }
    ],
    messages: messages
  };

  var options = {
    method: 'post',
    contentType: 'application/json',
    headers: {
      'x-api-key': apiKey,
      'anthropic-version': AI_CONFIG.API_VERSION,
      'anthropic-beta': 'prompt-caching-2024-07-31'  // WP-033: Enable prompt caching for cost savings
    },
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  };

  // WP-033: Retry once on 429 (rate limit) or 529 (overloaded) with backoff
  var resp = UrlFetchApp.fetch(AI_CONFIG.API_URL, options);
  var code = resp.getResponseCode();

  if (code === 429 || code === 529) {
    Logger.log('Claude API ' + code + ' — retrying after 3s backoff');
    Utilities.sleep(3000);
    resp = UrlFetchApp.fetch(AI_CONFIG.API_URL, options);
    code = resp.getResponseCode();
  }

  if (code !== 200) {
    var errBody = resp.getContentText();
    Logger.log('Claude API error ' + code + ': ' + errBody);
    throw new Error('AI service error (' + code + '). Please try again.');
  }

  var data = JSON.parse(resp.getContentText());
  return data.content[0].text;
}

// ─── Robust JSON Extraction ───
// Handles: code fences, leading/trailing prose, nested braces
function extractJson_(text) {
  // Strip code fences
  text = text.replace(/```json\s*/gi, '').replace(/```\s*/g, '').trim();

  // Try direct parse first (ideal case)
  try { return JSON.parse(text); } catch (e) {}

  // Find the first '{' and match to its closing '}'
  var start = text.indexOf('{');
  if (start < 0) {
    return { empathy: '', answer: text, action_steps: [], rights_reminder: null, watch_out: null, offer_to_draft: null, draft_type: null, sources: [] };
  }

  var depth = 0;
  var inString = false;
  var escape = false;
  var end = -1;

  for (var i = start; i < text.length; i++) {
    var c = text.charAt(i);
    if (escape) { escape = false; continue; }
    if (c === '\\') { escape = true; continue; }
    if (c === '"') { inString = !inString; continue; }
    if (inString) continue;
    if (c === '{') depth++;
    if (c === '}') { depth--; if (depth === 0) { end = i; break; } }
  }

  if (end > start) {
    var jsonStr = text.substring(start, end + 1);
    try { return JSON.parse(jsonStr); } catch (e) {
      Logger.log('JSON extraction parse error: ' + e.toString() + ' | extracted: ' + jsonStr.substring(0, 200));
    }
  }

  // Final fallback: wrap raw text
  Logger.log('JSON extraction failed completely. Raw text: ' + text.substring(0, 300));
  return { empathy: '', answer: text, action_steps: [], rights_reminder: null, watch_out: null, offer_to_draft: null, draft_type: null, sources: [] };
}

// ═══════════════════════════════════════════════════════
// AI ENGINE — Classification
// ═══════════════════════════════════════════════════════

function classifyQuestion_(question) {
  var systemPrompt = 'You classify parent questions about disability services in California.\n'
    + 'Return ONLY valid JSON — no markdown, no code fences, no explanation.\n'
    + 'Schema: { "category": "...", "urgency": "low|medium|high", "needs_action": true|false, "emotional_state": "calm|stressed|crisis", "tone_level": "collaborative|assertive|adversarial", "claim_context": "..." }\n\n'
    + 'Categories:\n'
    + '- regional-center: Regional Center, Early Start, IPP, vendored services, POS standards, Lanterman Act\n'
    + '- iep: IEP, 504, school services, evaluations, placement, FAPE, IDEA\n'
    + '- benefits: SSI, IHSS, Medi-Cal, CCS, ABLE, respite, SDP, reimbursements\n'
    + '- insurance: coverage, denials, appeals, prior auth, medical necessity, SB 946\n'
    + '- rights: fair hearings, complaints, legal rights, timelines, disputes, 4731\n'
    + '- navigation: general guidance, provider finding, system overview, getting started\n'
    + '- transitions: aging out, DOR, vocational rehab, conservatorship, adult services\n\n'
    + 'Urgency rules:\n'
    + '- high: deadlines within days, active denials, crisis situations, rights violations\n'
    + '- medium: upcoming meetings, pending applications, general concerns\n'
    + '- low: informational questions, planning ahead, general learning\n\n'
    + 'TONE LEVEL — this is critical:\n'
    + '- collaborative: STRONG DEFAULT — use this for ANY question that is informational, exploratory, process-oriented, or where the parent is not explicitly describing a conflict or denial. When in doubt, classify as collaborative.\n'
    + '- assertive: Parent is experiencing delays, getting the runaround, being told "no" informally, or feels something isn\'t right. They need to know their rights and stand firm, but haven\'t been formally denied yet.\n'
    + '- adversarial: Parent has received a formal denial, rights are being violated, deadlines are being missed despite requests, or they need to file complaints/appeals/hearings. Active conflict.\n\n'
    + 'CLAIM CONTEXT — briefly describe the specific situation:\n'
    + 'Examples: "pre-authorized reimbursement paperwork question", "first-time RC inquiry", "formal service denial needing appeal", "routine IEP prep", "school refusing evaluation request"\n'
    + 'This helps calibrate the response tone and content.';

  // WP-033: Use Haiku for classification — same quality at ~1/60th cost
  var result = callClaude_(systemPrompt, question, null, AI_CONFIG.MODEL_CLASSIFY);
  var parsed = extractJson_(result);

  // Validate classification has required fields, fallback if not
  if (!parsed.category) parsed.category = 'navigation';
  if (!parsed.urgency) parsed.urgency = 'medium';
  if (parsed.needs_action === undefined) parsed.needs_action = false;
  if (!parsed.emotional_state) parsed.emotional_state = 'calm';
  if (!parsed.tone_level) parsed.tone_level = 'collaborative';
  if (!parsed.claim_context) parsed.claim_context = '';
  return parsed;
}

// ═══════════════════════════════════════════════════════
// AI ENGINE — Knowledge Base Retrieval
// ═══════════════════════════════════════════════════════

function getRelevantKnowledge_(question, category, userDiagnosis) {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('KnowledgeBase');
  if (!sheet || sheet.getLastRow() <= 1) return '';

  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  var idCol = headers.indexOf('id');
  var catCol = headers.indexOf('category');
  var contentCol = headers.indexOf('content');
  var titleCol = headers.indexOf('title');
  var activeCol = headers.indexOf('active');

  // Diagnosis → journey category map
  var dxCategoryMap = {
    'autism': 'journey-autism', 'asd': 'journey-autism',
    'pda': 'journey-pda',
    'adhd': 'journey-adhd',
    'sli': 'journey-sli', 'speech': 'journey-sli',
    'sld': 'journey-sld', 'dyslexia': 'journey-sld',
    'id': 'journey-id', 'intellectual': 'journey-id',
    'down': 'journey-id', 'cp': 'journey-id',
    'epilepsy': 'journey-id'
  };

  // Determine user's journey category
  var journeyCat = '';
  if (userDiagnosis) {
    var dxLower = (Array.isArray(userDiagnosis) ? userDiagnosis[0] : userDiagnosis).toString().toLowerCase();
    journeyCat = dxCategoryMap[dxLower] || '';
  }

  // Filter active rows
  var activeRows = data.slice(1).filter(function(row) {
    var isActive = activeCol >= 0 ? (row[activeCol] === true || row[activeCol] === 'TRUE' || row[activeCol] === 'Yes') : true;
    return isActive;
  });

  if (activeRows.length === 0) return '';

  // WP-033: Keyword relevance scoring — include critical short domain terms
  var DOMAIN_TERMS = ['iep','ipp','ssi','aba','aac','rc','504','dor','oah','iee','sdp','ihss','fape',
    'idea','ada','ccs','snt','pti','bip','fba','pwn','nps','sdc','lre','esy','esw','med','cal','sdm'];
  var words = question.toLowerCase().split(/\s+/).filter(function(w) {
    return w.length > 3 || DOMAIN_TERMS.indexOf(w) >= 0;
  });

  var scored = activeRows.map(function(row) {
    var content = (row[contentCol] || '').toString().toLowerCase();
    var title = (row[titleCol] || '').toString().toLowerCase();
    var rowCat = (row[catCol] || '').toString();
    var score = 0;

    // Keyword matching
    words.forEach(function(word) {
      if (title.indexOf(word) >= 0) score += 3;
      if (content.indexOf(word) >= 0) score += 1;
    });

    // Category match boost
    if (rowCat === category) score += 2;

    // Diagnosis-specific journey boost
    if (journeyCat && rowCat === journeyCat) score += 5;

    // Cross-reference boost for eligibility questions
    if (rowCat === 'cross-reference' && userDiagnosis) {
      var dxName = (Array.isArray(userDiagnosis) ? userDiagnosis[0] : userDiagnosis).toString().toLowerCase();
      if (title.indexOf(dxName) >= 0 || content.indexOf(dxName) >= 0) score += 4;
    }

    // Age timeline boost for age/transition questions
    var ageWords = ['age', 'transition', 'turn', 'birthday', 'year', 'old', 'adult', 'school', 'preschool', 'toddler', 'teen'];
    if (rowCat === 'age-timeline') {
      ageWords.forEach(function(w) { if (question.toLowerCase().indexOf(w) >= 0) score += 2; });
    }

    // Equity boost
    var equityWords = ['equity', 'disparity', 'discrimination', 'fair', 'spanish', 'language', 'latino', 'rural', 'income', 'barrier'];
    if (rowCat === 'equity') {
      equityWords.forEach(function(w) { if (question.toLowerCase().indexOf(w) >= 0) score += 2; });
    }

    return { content: row[contentCol], title: row[titleCol], score: score, cat: rowCat };
  });

  // Return top 5 with balanced mix of journey + general articles
  var sorted = scored.sort(function(a, b) { return b.score - a.score; });
  var results = [];
  var journeyCount = 0;
  var generalCount = 0;

  for (var i = 0; i < sorted.length && results.length < 5; i++) {
    if (sorted[i].score <= 0) break;
    var isJourney = sorted[i].cat.indexOf('journey-') === 0;
    if (isJourney && journeyCount >= 3) continue;
    if (!isJourney && generalCount >= 3) continue;
    results.push(sorted[i]);
    if (isJourney) journeyCount++;
    else generalCount++;
  }

  return results
    .map(function(r) { return '## ' + r.title + '\n' + r.content; })
    .join('\n\n---\n\n');
}

// ═══════════════════════════════════════════════════════
// AI ENGINE — Category-Specific Prompts
// ═══════════════════════════════════════════════════════

function getCategoryPrompt_(category, userProfile, toneLevel, claimContext, actionSummary) {
  // Try to load from Prompts sheet
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('Prompts');
  if (sheet && sheet.getLastRow() > 1) {
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    var catCol = headers.indexOf('category');
    var promptCol = headers.indexOf('system_prompt');
    var activeCol = headers.indexOf('active');

    var row = data.slice(1).find(function(r) {
      return r[catCol] === category && (r[activeCol] === true || r[activeCol] === 'TRUE' || r[activeCol] === 'Yes');
    });

    if (row && row[promptCol]) {
      var prompt = row[promptCol].toString();
      prompt = injectProfileContext_(prompt, userProfile);
      prompt += buildActionContext_(actionSummary);
      prompt += getToneGuidance_(toneLevel, claimContext);
      return prompt;
    }
  }

  // Fallback: built-in prompts
  return getBuiltInPrompt_(category, userProfile, toneLevel, claimContext, actionSummary);
}

function injectProfileContext_(prompt, profile) {
  if (!profile) return prompt;
  // Build precise age string if available
  var ageStr = profile.age || 'not specified';
  if (profile.childAgeDisplay) {
    ageStr = profile.childAgeDisplay + ' (age band: ' + (profile.childAgeBand || profile.age || 'unknown') + ')';
  }
  return prompt
    .replace(/\{child_name\}/g, profile.childName || 'your child')
    .replace(/\{regional_center\}/g, profile.regionalCenter || 'your Regional Center')
    .replace(/\{school_district\}/g, profile.schoolDistrict || 'your school district')
    .replace(/\{diagnosis\}/g, profile.diagnosis || 'not specified')
    .replace(/\{age\}/g, ageStr)
    .replace(/\{insurance\}/g, profile.insurance || 'not specified')
    .replace(/\{rc_status\}/g, profile.rcStatus || 'unknown')
    .replace(/\{iep_status\}/g, profile.iepStatus || 'unknown')
    .replace(/\{benefits\}/g, profile.benefits || 'none specified');
}

// ─── WP-032: Action Plan Context Builder ───
function buildActionContext_(actionSummary) {
  if (!actionSummary || !actionSummary.total) return '';
  var ctx = '\nACTION PLAN CONTEXT (what this family has been working on):\n';
  ctx += '- Total actions: ' + actionSummary.total + '\n';
  ctx += '- Completed: ' + (actionSummary.completed || 0) + '\n';
  ctx += '- In progress: ' + (actionSummary.started || 0) + '\n';
  ctx += '- Remaining: ' + (actionSummary.pending || 0) + '\n';
  if (actionSummary.completedPct >= 50) {
    ctx += '- GREAT PROGRESS — this family is more than halfway through their plan!\n';
  }
  if (actionSummary.topPending && actionSummary.topPending.length > 0) {
    ctx += '- Next actions on their list:\n';
    for (var i = 0; i < actionSummary.topPending.length; i++) {
      ctx += '  ' + (i + 1) + '. ' + actionSummary.topPending[i] + '\n';
    }
  }
  if (actionSummary.recentCompleted && actionSummary.recentCompleted.length > 0) {
    ctx += '- Recently completed:\n';
    for (var j = 0; j < actionSummary.recentCompleted.length; j++) {
      ctx += '  ✓ ' + actionSummary.recentCompleted[j] + '\n';
    }
  }
  ctx += '\nUSE THIS CONTEXT: Reference their progress naturally. If they have completed actions, acknowledge it. '
    + 'If they have pending actions, you can suggest tackling one. Don\'t repeat information they already know from previous actions. '
    + 'If they are more than halfway through their plan, celebrate their progress and focus on advanced guidance.\n\n';
  return ctx;
}

// ─── Tone Guidance Generator ───
function getToneGuidance_(toneLevel, claimContext) {
  var tone = '\n\nTONE CALIBRATION — READ THIS CAREFULLY:\n';
  tone += 'Situation context: ' + (claimContext || 'general inquiry') + '\n\n';

  if (toneLevel === 'collaborative') {
    tone += 'TONE: COLLABORATIVE (warm, calm, personal)\n'
      + 'Imagine you are catching up with a friend over coffee. You happen to know a lot about disability services, '
      + 'but you lead with warmth, not expertise. You listen first, then share practical wisdom.\n\n'
      + 'ABSOLUTE RULES IN COLLABORATIVE MODE:\n'
      + '- NEVER cite statute numbers, section codes, or legal references in your answer or empathy — save them for "sources" only\n'
      + '- NEVER use phrases like "you are entitled to," "the law requires," "they must," "pursuant to," "under Section"\n'
      + '- INSTEAD use: "you can ask for," "the process is," "here\'s how it works," "a good first step is," "many families find it helpful to"\n'
      + '- Frame agencies (RC, school, insurance) as partners to work WITH — assume good intent first\n'
      + '- Service coordinators manage 60+ cases. Teachers are overworked. Delays are usually workload, not bad faith.\n\n'
      + 'CONVERSATIONAL STYLE:\n'
      + '- Start responses like you\'re talking to a friend: "Oh, that\'s a great question..." or "So here\'s the deal with..." or "OK, let me walk you through this..."\n'
      + '- Vary your opening — don\'t start every response the same way\n'
      + '- Use the child\'s name naturally throughout, like a friend would\n'
      + '- Share practical wisdom, not legal analysis: "What I\'d do in your shoes is..."\n'
      + '- When the parent is new to the system, explain ONE thing at a time — don\'t list five agencies at once\n'
      + '- For delays or slow responses: suggest a polite follow-up email or call, not a complaint\n'
      + '- For reimbursement delays: ASK whether it was pre-authorized first — that changes everything\n'
      + '- Set "rights_reminder" to null unless there\'s a genuinely helpful right they should know about\n'
      + '- End naturally — offer to help with the next step, not a formal closing\n'
      + '- If the family has been making progress on their action plan, acknowledge it! Celebrate small wins.\n';
  } else if (toneLevel === 'assertive') {
    tone += 'TONE: ASSERTIVE — BUT START COLLABORATIVE FIRST\n'
      + '- The parent may be experiencing pushback — but you DON\'T KNOW the full story yet\n'
      + '- CRITICAL: Your FIRST response should LEAD with a specific clarifying question about what steps they have already taken. '
      + 'Ask: Have they called? Emailed? Spoken to a supervisor? What communication has taken place?\n'
      + '- Structure your response: (1) Validate briefly, (2) Give preliminary guidance based on what they shared, '
      + '(3) Ask 1-2 SPECIFIC clarifying questions that will change your next response, (4) Note: "Once I understand what you\'ve already tried, I can give you more targeted guidance."\n'
      + '- DO NOT immediately jump to filing complaints, demanding meetings, or escalating. That may be premature.\n'
      + '- Example: If a parent says "RC hasn\'t paid me in 60 days" — ask if this was pre-authorized before advising a 4731 complaint. '
      + 'Service coordinators have 60+ caseloads. Start with empathy for both sides.\n'
      + '- If the parent HAS already tried normal channels and told you: THEN shift to firm advocacy language\n'
      + '- Use phrases like "you have the right to," "they are required to respond within X days," "ask them to put that in writing"\n'
      + '- Include one key legal citation that\'s directly relevant, but don\'t pile on multiple statutes\n'
      + '- Frame it as: "You\'re not being unreasonable — let\'s figure out the best approach for YOUR situation"\n';
  } else if (toneLevel === 'adversarial') {
    tone += 'TONE: ADVERSARIAL — BUT STILL VERIFY KEY FACTS FIRST\n'
      + '- The parent has likely been formally denied or their rights are being violated — but still ask ONE targeted clarifying question\n'
      + '- Ask: "Do you have the denial in writing?" "When was the Notice of Action dated?" "What reason did they give?"\n'
      + '- Then provide your full legal guidance — this IS the time for specific statutes and escalation\n'
      + '- For TIME-SENSITIVE situations (like the 10-day aid paid pending window): Lead with the URGENT action FIRST, then context\n'
      + '- Structure: (1) "Take a breath — here is what to do RIGHT NOW:" (2) Most urgent action with deadline (3) Supporting context and next steps (4) Free advocacy resources\n'
      + '- Use phrases like "they are in violation of," "you have the legal right to," "file a formal complaint"\n'
      + '- Provide exact statute numbers, filing deadlines, and escalation paths\n'
      + '- Include specific complaint mechanisms (4731, CDE, DMHC, fair hearing)\n'
      + '- ALWAYS mention Disability Rights California (1-800-776-5746) as free legal help\n'
      + '- Tell them what NOT to do: "Do NOT accept verbal promises. Do NOT sign agreement to reduced services."\n'
      + '- Frame it as: "This is serious, but you have rights and options — here is exactly what to do"\n';
  }

  return tone;
}

function getBuiltInPrompt_(category, profile, toneLevel, claimContext, actionSummary) {
  var base = 'You are Waypoint\'s AI Navigator — a knowledgeable, empathetic guide for parents of children with disabilities in California. '
