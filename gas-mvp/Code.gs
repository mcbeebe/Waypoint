// WP-029: Document Upload via Google Drive
// ═══════════════════════════════════════════════════════

function uploadDocument(userId, base64Data, fileName, mimeType, actionId) {
  try {
    // Create or get user's Waypoint folder
    var folderName = 'Waypoint Documents';
    var folders = DriveApp.getFoldersByName(folderName);
    var folder = folders.hasNext() ? folders.next() : DriveApp.createFolder(folderName);

    // Create sub-folder for user if needed
    var userFolders = folder.getFoldersByName(userId);
    var userFolder = userFolders.hasNext() ? userFolders.next() : folder.createFolder(userId);

    // Decode and save file
    var blob = Utilities.newBlob(Utilities.base64Decode(base64Data), mimeType, fileName);
    var file = userFolder.createFile(blob);

    // Log to Documents sheet
    var sheet = getOrCreateSheet_('Documents', [
      'id', 'userId', 'fileName', 'mimeType', 'driveFileId', 'driveUrl', 'actionId', 'uploadedAt'
    ]);
    var docId = Utilities.getUuid();
    sheet.appendRow([
      docId, userId, fileName, mimeType, file.getId(), file.getUrl(), actionId || '', new Date().toISOString()
    ]);

    return { success: true, docId: docId, driveUrl: file.getUrl(), fileName: fileName };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function getUserDocuments(userId) {
  try {
    var sheet = getOrCreateSheet_('Documents', [
      'id', 'userId', 'fileName', 'mimeType', 'driveFileId', 'driveUrl', 'actionId', 'uploadedAt'
    ]);
    if (sheet.getLastRow() < 2) return { success: true, documents: [] };
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    var docs = [];
    for (var i = 1; i < data.length; i++) {
      var row = {};
      for (var j = 0; j < headers.length; j++) row[headers[j]] = data[i][j];
      if (row.userId === userId) {
        docs.push({
          id: row.id, fileName: row.fileName, mimeType: row.mimeType,
          driveUrl: row.driveUrl, actionId: row.actionId,
          uploadedAt: row.uploadedAt
        });
      }
    }
    docs.sort(function(a,b){ return (b.uploadedAt||'').localeCompare(a.uploadedAt||''); });
    return { success: true, documents: docs };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

// ═══════════════════════════════════════════════════════
// WP-030: Persistent Chat History
// ═══════════════════════════════════════════════════════

function saveChatMessage(userId, sessionId, role, content, category) {
  try {
    var sheet = getOrCreateSheet_('ChatMessages', [
      'sessionId', 'userId', 'role', 'content', 'category', 'timestamp'
    ]);
    sheet.appendRow([
      sessionId, userId, role, content, category || '', new Date().toISOString()
    ]);

    // Update session metadata
    var sessSheet = getOrCreateSheet_('ChatSessions', [
      'sessionId', 'userId', 'startedAt', 'messageCount', 'lastCategory', 'title'
    ]);
    var sessData = sessSheet.getDataRange().getValues();
    var found = false;
    for (var i = 1; i < sessData.length; i++) {
      if (sessData[i][0] === sessionId) {
        sessSheet.getRange(i+1, 4).setValue((sessData[i][3] || 0) + 1);
        if (category) sessSheet.getRange(i+1, 5).setValue(category);
        found = true;
        break;
      }
    }
    if (!found) {
      var title = content.length > 60 ? content.substring(0, 57) + '...' : content;
      sessSheet.appendRow([sessionId, userId, new Date().toISOString(), 1, category || '', title]);
    }

    return { success: true };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function getChatSessions(userId) {
  try {
    var sheet = getOrCreateSheet_('ChatSessions', [
      'sessionId', 'userId', 'startedAt', 'messageCount', 'lastCategory', 'title'
    ]);
    if (sheet.getLastRow() < 2) return { success: true, sessions: [] };
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    var sessions = [];
    for (var i = 1; i < data.length; i++) {
      var row = {};
      for (var j = 0; j < headers.length; j++) row[headers[j]] = data[i][j];
      if (row.userId === userId) {
        sessions.push({
          sessionId: row.sessionId, title: row.title || 'Conversation',
          startedAt: row.startedAt, messageCount: row.messageCount || 0,
          lastCategory: row.lastCategory || ''
        });
      }
    }
    sessions.sort(function(a,b){ return (b.startedAt||'').localeCompare(a.startedAt||''); });
    return { success: true, sessions: sessions };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}

function getChatMessages(sessionId) {
  try {
    var sheet = getOrCreateSheet_('ChatMessages', [
      'sessionId', 'userId', 'role', 'content', 'category', 'timestamp'
    ]);
    if (sheet.getLastRow() < 2) return { success: true, messages: [] };
    var data = sheet.getDataRange().getValues();
    var headers = data[0];
    var msgs = [];
    for (var i = 1; i < data.length; i++) {
      var row = {};
      for (var j = 0; j < headers.length; j++) row[headers[j]] = data[i][j];
      if (row.sessionId === sessionId) {
        msgs.push({ role: row.role, content: row.content, timestamp: row.timestamp });
      }
    }
    msgs.sort(function(a,b){ return (a.timestamp||'').localeCompare(b.timestamp||''); });
    return { success: true, messages: msgs };
  } catch (e) {
    return { success: false, error: e.toString() };
  }
}
