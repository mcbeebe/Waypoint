EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry crash reporting (optional — app works without it)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# To set up:
# 1. Create a Supabase project at https://supabase.com
# 2. Copy your Project URL and anon key from Settings → API
# 3. Enable pgvector extension in Database → Extensions
# 4. (Optional) Create a Sentry project at https://sentry.io for crash reporting
# 5. Copy this file to .env and fill in your values
