{
  "expo": {
    "name": "Waypoint",
    "slug": "waypoint",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.waypoint.app",
      "usesAppleSignIn": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Waypoint uses the camera to scan documents for your Document Vault.",
        "NSPhotoLibraryUsageDescription": "Waypoint accesses your photos to upload documents to your Document Vault.",
        "CFBundleLocalizations": ["en", "es", "vi"],
        "CFBundleDevelopmentRegion": "en"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2A4A"
      },
      "package": "com.waypoint.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-asset"
    ],
    "scheme": "waypoint",
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID"
    },
    "locales": {
      "en": "./assets/locales/en.json",
      "es": "./assets/locales/es.json",
      "vi": "./assets/locales/vi.json"
    }
  }
}
